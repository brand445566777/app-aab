{
  "expo": {
    "name": "Pakistan Emergency Helpline",
    "slug": "pakistan-emergency-helpline",
    "version": "3.0.2",
    "icon": "./assets/images/icon.png",
    "scheme": "manust20260304040534",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "orientation": "default",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "space.manus.pakistan.emergency.helpline.t20260304040534",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "minSdkVersion": 24,
      "targetSdkVersion": 35,
      "compileSdkVersion": 36,
      "versionCode": 10039,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#0A3D62",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "space.manus.pakistan.emergency.helpline.t20260304040534",
      "permissions": [
        "POST_NOTIFICATIONS",
        "com.google.android.gms.permission.AD_ID",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "manust20260304040534",
              "host": "*"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "usesCleartextTraffic": false,
      "enableOnBackInvokedCallback": true,
      "resizeableActivity": true,
      "supportsRtl": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/admob-mediation-plugin.js",
      "./plugins/play-console-compliance-plugin.js",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "buildArchs": [
              "armeabi-v7a",
              "arm64-v8a",
              "x86",
              "x86_64"
            ],
            "minSdkVersion": 24,
            "targetSdkVersion": 35,
            "compileSdkVersion": 36,
            "kotlinVersion": "2.1.20"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3617790148719581~6917999502",
          "iosAppId": "ca-app-pub-3617790148719581~6917999502"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "appVersion": "3.0.2",
      "androidAppId": "ca-app-pub-3617790148719581~6917999502",
      "router": {},
      "eas": {
        "projectId": "1dce1176-d507-4ec5-8322-9e9f10b65bff"
      }
    }
  }
}
